# ============================================================
# MinecraftLM / MapCraft — environment variables
# Copy to backend/.env for local development
# Set these in the Railway dashboard for production
# ============================================================

# ── LLM providers (at least one required) ───────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Default model ────────────────────────────────────────────
# LLM_MODEL=gemini-2.5-flash-preview-04-17

# ── Stripe (required for paid downloads) ────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Public URL (used in Stripe success/cancel redirect URLs) ─
# Local dev:
PUBLIC_URL=http://localhost:5173
# Railway (replace with your actual Railway domain):
# PUBLIC_URL=https://mapcraft-production.up.railway.app

# ── Storage path (Railway: mount volume at /data, set this) ──
# Local default: <project-root>/.storage/sessions
# Railway:
# STORAGE_PATH=/data/sessions

# ── Server ───────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=INFO
